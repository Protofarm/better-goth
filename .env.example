# better-goth example app settings
APP_PORT=3000

# Development mode - use HTTP instead of HTTPS (for development only!)
# Set to true for development, false or unset for production
DEV_MODE=true

# OAuth server configuration
OAUTH_SERVER_ISSUER_URL=http://localhost:8080
OAUTH_SERVER_PORT=8080
OAUTH_SERVER_CLIENT_ID=my-client
OAUTH_SERVER_CLIENT_SECRET=my-secret
OAUTH_SERVER_KEY_FILE=private.pem
OAUTH_SERVER_REDIRECT_URIS=http://localhost:3000/callback/oauthserver

# JWT and session configuration
JWT_SECRET=replace-with-at-least-32-bytes-secret

# TLS/HTTPS configuration (required in production when DEV_MODE=false)
# Only needed when running HTTPS - leave empty to use HTTP
OAUTH_SERVER_TLS_CERT=
OAUTH_SERVER_TLS_KEY=

# Google OAuth provider (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notes for Production:
# 1. Set DEV_MODE=false or remove it
# 2. Use HTTPS URLs for all OAuth endpoints
# 3. Provide valid TLS certificate and key paths
# 4. Use a strong JWT_SECRET (32+ bytes)
# 5. Configure proper redirect URIs

